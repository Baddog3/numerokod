# Скопируйте в .env.deploy и заполните данными из ispmanager → FTP-пользователи
# Путь к папке сайта: ispmanager → WWW-домены → numerokod.ru → Корневая директория

FTP_HOST=your-server.firstbyte.ru
FTP_USER=your_ftp_login
FTP_PASS=your_ftp_password
FTP_PORT=21
FTP_PROTOCOL=ftp
FTP_REMOTE_DIR=/www/numerokod.ru
